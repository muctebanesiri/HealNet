---
import Layout from "../layouts/MainLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

import Hero from "../components/homepage/Hero.astro";
import CtaForm from "../components/homepage/CtaForm.astro";
import Services from "../components/homepage/Services.astro";
import Story from "../components/homepage/Story.astro";
import HowWorks from "../components/homepage/HowWorks.astro";
import Testimonials from "../components/homepage/Testimonials.astro";
import Team from "../components/homepage/Team.astro";
import Support from "../components/homepage/Support.astro";
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<Hero />
	<CtaForm />
	<Services />
	<Story />	
	<HowWorks />
	<Testimonials />
	<Team />
	<Support />
</Layout>
