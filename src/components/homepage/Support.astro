---
import { UserRound, Mail, CircleChevronRight } from "@lucide/astro";
---

<section class="section">
  <div class="container">
    <hgroup class="text-center max-w-5xl mx-auto">
      <h2>
        Reach our <span
          class="bg-linear-to-r from-[#0179B4] to-[#88D8FF] bg-clip-text text-transparent"
          >Help Desk</span
        > for support
      </h2>
      <p>
        Questions? Need assistance? Our dedicated support team is here to help
        you every step of the way:
      </p>
    </hgroup>

    <form action="/" class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-4 max-w-100 lg:max-w-5xl mx-auto" method="POST">
      <label class="input validator w-full h-auto! border-main-200 rounded-xl">
        <UserRound class="text-main-200"/>
        <input class="  py-3 px-6 text-lg" type="text" required placeholder="Enter Your First Name" />
      </label>
	   <label class="input validator w-full h-auto! border-main-200 rounded-xl">
        <Mail class="text-main-200"/>
        <input class="  py-3 px-6 text-lg" type="email" required placeholder="Enter Your Email Address" />
      </label>
	  						<button type="submit" class="btn bg-[linear-gradient(125deg,var(--color-main-100),var(--color-main-200))] text-white border-0 rounded-xl text-lg py-3 px-6 h-auto shadow-xl hover:shadow-2xl w-full">Contact us<CircleChevronRight /></button>

    </form>
  </div>
</section>
